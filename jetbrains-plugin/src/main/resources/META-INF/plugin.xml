<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.qoocode.jetbrains</id>
    <name>qoocode</name>
    <version>0.1.30</version>
    <vendor email="qoocode@example.com" url="https://qoocode.example.com">qoocode Team</vendor>
    
    <description>
        qoocode - AI-Powered Code Assistant for JetBrains IDEs
        
        Features:
        - AI Chat Interface
        - Code Analysis and Refactoring
        - Git Integration
        - Terminal Integration
        - File Operations
        - Search and Navigation
        - Test Generation
        - Documentation Generation
    </description>
    
    <category>AI Tools</category>
    
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>com.intellij.modules.terminal</depends>
    
    <extensionPoints>
        <extensionPoint name="QooCode.tool" interface="qoocode.plugin.QooCodeTool"/>
        <extensionPoint name="QooCode.command" interface="qoocode.plugin.QooCodeCommand"/>
    </extensionPoints>
    
    <extensions defaultExtensionNs="com.intellij">
        <!-- Application configuration -->
        <applicationConfigurable instance="qoocode.plugin.QooCodeConfigurable"/>
        
        <!-- Project settings -->
        <projectConfigurable instance="qoocode.plugin.QooCodeProjectConfigurable"/>
        
        <!-- Tool window factory -->
        <toolWindowFactory implementation="qoocode.plugin.QooCodeToolWindowFactory"/>
        
        <!-- Status bar widget -->
        <StatusBarWidgetFactory id="QooCode.status" implementation="qoocode.plugin.QooCodeStatusBarWidget"/>
        
        <!-- Editor actions -->
        <actionGroup id="QooCode.Actions">
            <action id="QooCode.Chat" 
                    class="qoocode.plugin.actions.QooCodeChatAction"
                    text="QooCode Chat"
                    description="Open QooCode chat interface">
                <add-to-group group-id="ToolsMenu" anchor="last"/>
                <add-to-group group-id="MainToolbar" anchor="last"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift o"/>
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift o"/>
            </action>
            
            <action id="QooCode.AnalyzeFile"
                    class="qoocode.plugin.actions.QooCodeAnalyzeAction"
                    text="Analyze with QooCode"
                    description="Analyze current file with QooCode">
                <add-to-group group-id="CodeMenu" anchor="last"/>
            </action>
            
            <action id="QooCode.Explain"
                    class="qoocode.plugin.actions.QooCodeExplainAction"
                    text="Explain Code"
                    description="Explain selected code">
                <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            </action>
            
            <action id="QooCode.Refactor"
                    class="qoocode.plugin.actions.QooCodeRefactorAction"
                    text="Refactor with QooCode"
                    description="Refactor selected code">
                <add-to-group group-id="RefactoringMenu" anchor="last"/>
            </action>
            
            <action id="QooCode.GenerateTest"
                    class="qoocode.plugin.actions.QooCodeGenerateTestAction"
                    text="Generate Test"
                    description="Generate test for selected code">
                <add-to-group group-id="NewGroup" anchor="last"/>
            </action>
            
            <separator/>
            
            <action id="QooCode.Settings"
                    class="qoocode.plugin.actions.QooCodeSettingsAction"
                    text="QooCode Settings"
                    description="Configure QooCode settings">
                <add-to-group group-id="PreferencesMenu" anchor="last"/>
            </action>
        </actionGroup>
        
        <!-- Notifications -->
        <notificationGroup id="QooCode.notifications" displayType="BALLOON"/>
        
        <!-- File icons -->
        <fileIconProvider implementation="qoocode.plugin.QooCodeFileIconProvider"/>
        
        <!-- Quick fixes -->
        <intentionAction>
            <category>QooCode</category>
            <class>qoocode.plugin.intentions.QooCodeQuickFix</class>
        </intentionAction>
    </extensions>
    
    <actions>
        <!-- Main toolbar action -->
        <action id="QooCode.main.action" class="qoocode.plugin.actions.QooCodeMainAction"
                text="QooCode" description="QooCode AI Assistant">
            <add-to-group group-id="MainToolbar" anchor="after" relative-to-action="ToolbarMainAction"/>
        </action>
    </actions>
    
    <properties>
        <property name="QooCode.api.url" value="http://localhost:8080"/>
        <property name="QooCode.api.key" value=""/>
        <property name="QooCode.auto.start" value="false"/>
        <property name="QooCode.telemetry.enabled" value="true"/>
    </properties>
    
    <changeNotes>
        <![CDATA[
        <version 0.1.30>
            - Initial JetBrains plugin release
            - Chat interface
            - Code analysis
            - Git integration
            - Terminal integration
            - File operations
            - Search and navigation
        </version>
        ]]>
    </changeNotes>
</idea-plugin>
