<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>com.qoocode.jetbrains</id>
    <name>qoocode</name>
    <version>0.1.30</version>
    <vendor email="qoocode@example.com" url="https://qoocode.example.com">qoocode Team</vendor>
    
    <description>
        qoocode - AI-Powered Code Assistant for JetBrains IDEs

        Features:
        - Full qoocode CLI Terminal Integration (59+ tools, 63+ commands)
        - AI Chat Interface with Streaming Response
        - Code Analysis and Refactoring
        - Git Integration
        - File Operations
        - Search and Navigation
        - Test Generation
        - Documentation Generation
        - Built-in qoocode.exe binary (no separate installation required)

        Terminal Features:
        - All 59+ qoocode tools available (File operations, Grep, Git, etc.)
        - All 63+ slash commands (/help, /clear, /model, /plan, etc.)
        - Real-time interaction with AI assistant
        - ANSI color support and progress bars
        - qoocode.exe is bundled with the plugin
    </description>

    <category>AI Tools</category>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>
    
    <extensionPoints>
        <extensionPoint name="QooCode.tool" interface="qoocode.plugin.QooCodeTool"/>
        <extensionPoint name="QooCode.command" interface="qoocode.plugin.QooCodeCommand"/>
    </extensionPoints>
    
    <extensions defaultExtensionNs="com.intellij">
        <!-- Application configuration service -->
        <applicationService serviceImplementation="qoocode.plugin.QooCodeConfig"/>

        <!-- Application configuration -->
        <applicationConfigurable
            id="QooCode"
            displayName="QooCode"
            instance="qoocode.plugin.QooCodeConfigurable"
            groupId="tools"/>

        <!-- Project settings -->
        <projectConfigurable
            id="QooCode.Project"
            displayName="QooCode (Project)"
            instance="qoocode.plugin.QooCodeProjectConfigurable"
            groupId="tools"/>
        
        <!-- Tool window factory -->
        <toolWindow id="QooCode"
                    factoryClass="qoocode.plugin.QooCodeToolWindowFactory"
                    anchor="right"
                    icon="/META-INF/pluginIcon.svg"/>
        
        <!-- Status bar widget -->
        <StatusBarWidgetFactory id="QooCode.status" implementation="qoocode.plugin.QooCodeStatusBarWidget"/>
        
        <!-- Editor actions -->
        <actionGroup id="QooCode.Actions">
            <action id="QooCode.Terminal"
                    class="qoocode.plugin.actions.QooCodeTerminalAction"
                    text="QooCode Terminal"
                    description="Open QooCode terminal interface">
                <add-to-group group-id="ToolsMenu" anchor="first"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift t"/>
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift t"/>
            </action>
            
            <action id="QooCode.Chat"
                    class="qoocode.plugin.actions.QooCodeChatAction"
                    text="QooCode Chat"
                    description="Open QooCode chat interface">
                <add-to-group group-id="ToolsMenu" anchor="after" relative-to-action="QooCode.Terminal"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift o"/>
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift o"/>
            </action>
            
            <action id="QooCode.AnalyzeFile"
                    class="qoocode.plugin.actions.QooCodeAnalyzeAction"
                    text="Analyze with QooCode"
                    description="Analyze current file with QooCode">
                <add-to-group group-id="CodeMenu" anchor="last"/>
            </action>
            
            <action id="QooCode.Explain"
                    class="qoocode.plugin.actions.QooCodeExplainAction"
                    text="Explain Code"
                    description="Explain selected code">
                <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            </action>
            
            <action id="QooCode.Refactor"
                    class="qoocode.plugin.actions.QooCodeRefactorAction"
                    text="Refactor with QooCode"
                    description="Refactor selected code">
                <add-to-group group-id="RefactoringMenu" anchor="last"/>
            </action>
            
            <action id="QooCode.GenerateTest"
                    class="qoocode.plugin.actions.QooCodeGenerateTestAction"
                    text="Generate Test"
                    description="Generate test for selected code">
                <add-to-group group-id="NewGroup" anchor="last"/>
            </action>
            
            <separator/>
            
            <action id="QooCode.Settings"
                    class="qoocode.plugin.actions.QooCodeSettingsAction"
                    text="QooCode Settings"
                    description="Configure QooCode settings">
                <add-to-group group-id="PreferencesMenu" anchor="last"/>
            </action>
        </actionGroup>
        
        <!-- Notifications -->
        <notificationGroup id="QooCode.notifications" displayType="BALLOON"/>

        <!-- Quick fixes -->
        <intentionAction>
            <category>QooCode</category>
            <class>qoocode.plugin.intentions.QooCodeQuickFix</class>
        </intentionAction>
    </extensions>
    
    <actions>
        <!-- Main toolbar action -->
        <action id="QooCode.main.action" class="qoocode.plugin.actions.QooCodeMainAction"
                text="QooCode" description="QooCode AI Assistant">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift q"/>
        </action>

        <!-- Main menu action -->
        <action id="QooCode.menu.action" class="qoocode.plugin.actions.QooCodeMainAction"
                text="QooCode AI Assistant" description="Open QooCode AI Assistant">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
