{
  "name": "@qoobot/qoocode",
  "version": "0.1.16",
  "description": "Open-source AI coding assistant CLI - compatible with OpenAI/DeepSeek APIs",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "qoocode": "dist/main.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/main.tsx",
    "build": "bun build src/main.tsx --outdir dist --target bun",
    "build:compile": "bun build --compile src/main.tsx --outfile qoocode",
    "build:plugin": "cd jetbrains-plugin && ./gradlew.bat buildPlugin",
    "build:all": "bun run build && bun run build:compile && bun run build:plugin",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "coding",
    "openai",
    "deepseek",
    "anthropic",
    "llm",
    "gpt",
    "claude"
  ],
  "author": "qoobots",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/qoobots/qoocode.git"
  },
  "bugs": {
    "url": "https://github.com/qoobots/qoocode/issues"
  },
  "homepage": "https://github.com/qoobots/qoocode#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^13.1.0",
    "ansi-escapes": "^7.0.0",
    "chalk": "^5.4.1",
    "cli-cursor": "^4.0.0",
    "commander": "^13.1.0",
    "eventsource-parser": "^3.0.6",
    "ink": "^5.1.0",
    "lodash-es": "^4.17.21",
    "micromatch": "^4.0.8",
    "openai": "^4.82.0",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "slice-ansi": "^7.1.0",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "@types/react": "^18.3.18",
    "@types/lodash-es": "^4.17.12",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
